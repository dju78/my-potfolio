<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle or "Daramola Joseph Omoyele | Daramola Digital Labs" }}</title>
    <meta name="description" content="{{ pageDescription or 'Portfolio of Daramola Joseph Omoyele, Data Analyst, Research Analyst and Digital Product Builder. Showcasing data projects, research publications, dashboards, compliance tools and digital products under Daramola Digital Labs.' }}">
    <meta property="og:title" content="{{ pageTitle or 'Daramola Joseph Omoyele | Portfolio' }}">
    <meta property="og:description" content="{{ pageDescription or 'Portfolio of Daramola Joseph Omoyele, Data Analyst, Research Analyst and Digital Product Builder.' }}">
    <meta property="og:image" content="/djo-portfolio-logo.png">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://daramolajo.co.uk{{ page.url }}">
    <link rel="icon" type="image/png" href="/djo-portfolio-logo.png">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Daramola Joseph Omoyele",
      "url": "https://daramolajo.co.uk/",
      "logo": "https://daramolajo.co.uk/djo-portfolio-logo.png",
      "image": "https://daramolajo.co.uk/djo-portfolio-logo.png",
      "jobTitle": "Data Analyst and Digital Product Builder"
    }
    </script>
</head>

<body>

    <!-- ===================== NAVBAR ===================== -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                <img src="/djo-portfolio-logo.png" alt="DJO professional portfolio logo" title="Daramola Joseph Omoyele Logo" class="nav-logo-img">
            </a>
            <ul class="nav-menu" id="navMenu">
                {% set h = "" if page.url == "/" else "/" %}
                <li><a href="{{ h }}#home"       class="nav-link{% if page.url == '/' %} active{% endif %}">Home</a></li>
                <li><a href="{{ h }}#featured-policy" class="nav-link">Featured</a></li>
                <li><a href="{{ h }}#projects"   class="nav-link">Projects</a></li>
                <li><a href="{{ h }}#research"   class="nav-link">Research</a></li>
                <li><a href="/policy-contributions/" class="nav-link{% if page.url == '/policy-contributions/' %} active{% endif %}">Policy</a></li>
                <li><a href="{{ h }}#skills"     class="nav-link">CV</a></li>
                <li><a href="{{ h }}#contact"    class="nav-link">Contact</a></li>
            </ul>
            <div class="nav-right">
                <a href="{{ h }}#contact" class="nav-cta">Let's Connect</a>
                <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>
    </nav>

    {% if page.url != "/" %}
    <div class="subpage-back-wrap container">
        <a href="/" class="back-link">← Back to Portfolio</a>
    </div>
    {% endif %}

    {{ content | safe }}

    <!-- ===================== FOOTER ===================== -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <div class="footer-logo">
                        <img src="/djo-portfolio-logo.png" alt="DJO professional portfolio logo" title="Daramola Joseph Omoyele Logo" height="48" loading="lazy">
                        <div>
                            <div class="footer-brand-tagline">Data-driven tools for smarter decisions</div>
                        </div>
                    </div>
                </div>
                <div class="footer-links">
                    <a href="{{ h }}#home">Home</a>
                    <a href="{{ h }}#featured-policy">Featured</a>
                    <a href="/experience/">Experience</a>
                    <a href="/projects/">Projects</a>
                    <a href="/academic-work/">Research</a>
                    <a href="/policy-contributions/">Policy</a>
                    <a href="{{ h }}#skills">Skills</a>
                    <a href="/publications/">Publications</a>
                    <a href="{{ h }}#contact">Contact</a>
                </div>
                <div class="footer-social">
                    <a href="https://github.com/dju78" target="_blank" rel="noopener" aria-label="GitHub" class="social-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
                    </a>
                    <a href="mailto:dju78@omoyelejd.co.uk" aria-label="Email" class="social-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v.01L12 13 20 6.01V6H4zm0 12h16V8.99l-8 6.5-8-6.5V18z"/></svg>
                    </a>
                    <a href="https://orcid.org/0009-0006-0347-0499" target="_blank" rel="noopener" aria-label="ORCID" class="social-icon">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-9h2v9h-2zm0-10.5V4.5h2V6h-2z"/></svg>
                    </a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; <span id="footer-year">2026</span> Daramola Digital Labs. All rights reserved. · Portfolio of Daramola Joseph Omoyele.</p>
            </div>
        </div>
    </footer>

    <script src="/script.js"></script>
</body>
</html>
