---
layout: base.njk
permalink: /certifications/index.html
pageTitle: "Certifications & Professional Learning | Daramola Joseph Omoyele"
pageDescription: "Professional certifications and continuing education completed by Daramola Joseph Omoyele."
---
<section id="certifications" class="section certlearn-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Professional Learning</span>
            <h2 class="section-title">Certifications &amp; Professional Learning</h2>
        </div>
        <div class="certlearn-grid">
            {% for item in collections.certifications | reverse %}
            <div class="certlearn-card reveal">
                <h3>{{ item.data.title }}</h3>
                <p class="certlearn-provider">{{ item.data.provider }}</p>
                {% if item.data.date_display %}<p class="certlearn-date">Completed {{ item.data.date_display }}</p>{% endif %}
                {% if item.data.cert_no %}<p class="certlearn-no">Certificate No: {{ item.data.cert_no }}</p>{% endif %}
                <p class="certlearn-relevance">{{ item.data.relevance }}</p>
                <div class="policy-tags">
                    {% for tag in item.data.tags %}<span class="policy-tag">{{ tag }}</span>{% endfor %}
                </div>
                {% if item.data.verify %}
                <a href="{{ item.data.verify }}" target="_blank" rel="noopener" class="btn btn-soft btn-sm certlearn-btn">Verify Certificate</a>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>
