                        <div class="pub-icon">📄</div>
                        <h3>{{ paper.data.title }}</h3>
                        <p class="pub-meta">{{ paper.data.journal }}{% if paper.data.year %} ({{ paper.data.year }}){% endif %}</p>
                        {% if paper.data.doi %}<p class="pub-doi"><a href="{{ paper.data.doi }}" target="_blank" rel="noopener">DOI Link</a></p>{% endif %}
                        <div class="pub-description pub-collapsible collapsed">{{ paper.templateContent | safe }}</div>
                        <button class="read-more-btn" aria-expanded="false">Read more ▾</button>
                        {% if paper.data.contributors %}<div class="pub-contributors"><strong>Contributors:</strong> {{ paper.data.contributors }}</div>{% endif %}
                        <a href="{{ paper.data.doi }}" target="_blank" rel="noopener" class="pub-link">View Preprint →</a>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section books">
                <h3 class="pub-category-title"><span>Books</span> &amp; Handbooks</h3>
                <div class="publications-grid">
                    {% for book in collections.books | reverse %}
                    <div class="publication-card book-card flip-card reveal">
                        <div class="flip-card-inner">
                            <div class="flip-card-front">
                                <img src="{{ book.data.image }}" alt="{{ book.data.title }} Cover" class="book-cover-img" loading="lazy"/>
                                <div class="flip-hint">Hover to read more</div>
                            </div>
                            <div class="flip-card-back">
                                <h3>{{ book.data.title }}</h3>
                                {% if book.data.subtitle %}<p class="pub-subtitle"><em>{{ book.data.subtitle }}</em></p>{% endif %}
                                <p class="pub-meta">Independently published ({{ book.data.year }})</p>
                                {% if book.data.isbn %}<p class="pub-isbn">ISBN: {{ book.data.isbn }}</p>{% endif %}
                                {% if book.data.asin %}<p class="pub-isbn">ASIN: {{ book.data.asin }}</p>{% endif %}
                                <div class="pub-description">{{ book.templateContent | safe }}</div>
                                <a href="{{ book.data.link }}" target="_blank" rel="noopener" class="pub-link">View on Amazon →</a>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section policy-media">
                <h3 class="pub-category-title"><span>Public</span> Engagement &amp; Policy Commentary</h3>
                <div class="publications-grid">
                    <div class="publication-card media-card reveal">
                        <div class="pub-icon">📰</div>
                        <h3>Media &amp; Policy Commentary</h3>
                        <p class="pub-media-intro">Consistently translating economic evidence into public policy debate for wider audiences across major Nigerian media outlets.</p>
                        <div class="media-list">
                            {% for item in collections.media | reverse %}
                            <div class="media-item">
                                <h4>{{ item.data.title }}</h4>
                                <p class="media-description">{{ item.data.description }} <span class="media-date">({{ item.data.date_issued }})</span></p>
                                <div class="coverage-details">
                                    <span class="coverage-label">Published in:</span>
                                    <div class="coverage-links">
                                        {% for source in item.data.coverage %}
                                        {% if source.url %}<a href="{{ source.url }}" target="_blank" rel="noopener" class="news-pill">{{ source.source }}</a>{% else %}<span class="news-pill news-pill-plain">{{ source.source }}</span>{% endif %}
                                        {% endfor %}
                                    </div>
                                    {% if item.data.other_platforms %}<p class="other-coverage">{{ item.data.other_platforms }}</p>{% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="interests-section">
                <h3>Professional Interests</h3>
                <div class="interests-tags">
                    <span class="interest-tag">Economic regulation and innovation</span>
                    <span class="interest-tag">Data protection and privacy economics</span>
