    <!-- ===================== POLICY CONTRIBUTIONS ===================== -->
    <section id="policy" class="section policy-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Policy Engagement</span>
                <h2 class="section-title">Policy Contributions &amp; Consultation Responses</h2>
            </div>
            <div class="policy-intro">
                <p>I contribute independent policy analysis and consultation responses across UK tax administration, data governance, automated decision-making, energy data regulation, climate-related compliance, and public-sector digital reform.</p>
                <p>My work combines data analysis, economic reasoning, compliance insight, behavioural understanding, and practical implementation recommendations. The focus is on improving data quality, strengthening audit trails, reducing avoidable compliance failure, supporting proportionate regulation, and making public systems easier for people and organisations to use correctly.</p>
            </div>
            <div class="policy-grid">
                {% for item in collections.policy_contributions %}
                <div class="policy-card reveal">
                    <span class="policy-area">{{ item.data.area }}</span>
                    <h3>{{ item.data.title }}</h3>
                    <p class="policy-desc">{{ item.data.description }}</p>
                    <div class="policy-tags">
                        {% for tag in item.data.tags %}<span class="policy-tag">{{ tag }}</span>{% endfor %}
                    </div>
                    {% if item.data.pdf %}
                    <a href="{{ item.data.pdf }}" target="_blank" rel="noopener" class="btn btn-soft btn-sm policy-btn">{{ item.data.pdf_label or "Read Submission" }}</a>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- ===================== EXTERNAL MENTIONS ===================== -->
    <section id="external-mentions" class="section mentions-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Research Visibility</span>
                <h2 class="section-title">External Mentions &amp; Research Visibility</h2>
            </div>
            <div class="mentions-grid">
                {% for item in collections.external_mentions | reverse %}
                <div class="mention-card reveal">
                    <div class="mention-meta">
                        <span class="mention-type">{{ item.data.mention_type }}</span>
                        {% if item.data.date_display %}<span class="mention-date">{{ item.data.date_display }}</span>{% endif %}
                    </div>
                    <h3>{{ item.data.title }}</h3>
                    {% if item.data.source %}<p class="mention-source"><strong>Source:</strong> {{ item.data.source }}</p>{% endif %}
                    <p class="mention-desc">{{ item.data.description }}</p>
                    {% if item.data.papers %}
                    <div class="mention-papers">
                        <span class="mention-papers-label">Papers mentioned:</span>
                        <ul>{% for p in item.data.papers %}<li>{{ p }}</li>{% endfor %}</ul>
                    </div>
                    {% endif %}
                    <div class="policy-tags">
                        {% for tag in item.data.tags %}<span class="policy-tag">{{ tag }}</span>{% endfor %}
                    </div>
                    {% if item.data.link %}
                    <a href="{{ item.data.link }}" target="_blank" rel="noopener" class="btn btn-soft btn-sm mention-btn">{{ item.data.button_text or "View Mention" }}</a>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

