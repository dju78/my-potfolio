    <!-- ===================== PUBLICATIONS ===================== -->
    <section id="publications" class="section publications-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Thought Leadership</span>
                <h2 class="section-title">Publications &amp; Public Engagement</h2>
            </div>

            <div class="pub-section journal-articles">
                <h3 class="pub-category-title"><span>Published</span> Journal Articles</h3>
                <div class="publications-grid">
                    {% for article in collections.journal_articles | reverse %}
                    <div class="publication-card journal-card reveal">
                        <div class="pub-icon">📄</div>
                        <h3>{{ article.data.title }}</h3>
                        <p class="pub-meta">{{ article.data.journal }}{% if article.data.year %} ({{ article.data.year }}){% endif %}</p>
                        {% if article.data.doi %}<p class="pub-doi"><a href="{{ article.data.doi }}" target="_blank" rel="noopener">DOI Link</a></p>{% endif %}
                        <div class="pub-description pub-collapsible collapsed">{{ article.templateContent | safe }}</div>
                        <button class="read-more-btn" aria-expanded="false">Read more ▾</button>
                        {% if article.data.contributors %}<div class="pub-contributors"><strong>Contributors:</strong> {{ article.data.contributors }}</div>{% endif %}
                        <a href="{{ article.data.doi }}" target="_blank" rel="noopener" class="pub-link">View Journal Article →</a>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section preprints">
