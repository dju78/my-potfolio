---
layout: base.njk
pageTitle: "Daramola Joseph Omoyele | Daramola Digital Labs"
pageDescription: "Portfolio of Daramola Joseph Omoyele, Data Analyst, Research Analyst and Digital Product Builder. Showcasing data projects, research publications, dashboards, compliance tools and digital products under Daramola Digital Labs."
---
    <!-- ===================== HERO ===================== -->
    <section id="home" class="hero">
        <!-- Background layers -->
        <div class="hero-bg" aria-hidden="true">
            <div class="hero-grid"></div>
            <div class="hero-glow hero-glow-1"></div>
            <div class="hero-glow hero-glow-2"></div>
            <!-- Chart decoration SVG -->
            <svg class="hero-chart-deco" viewBox="0 0 700 420" fill="none" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                <path d="M20 380 L110 300 L200 330 L300 210 L390 260 L480 140 L580 175 L680 70" stroke="#C49A2C" stroke-width="1.5" stroke-dasharray="6 3" opacity="0.35"/>
                <circle cx="110" cy="300" r="4" fill="#C49A2C" opacity="0.45"/>
                <circle cx="300" cy="210" r="5" fill="#C49A2C" opacity="0.5"/>
                <circle cx="480" cy="140" r="6" fill="#C49A2C" opacity="0.55"/>
                <circle cx="680" cy="70"  r="4" fill="#C49A2C" opacity="0.45"/>
                <rect x="90"  y="320" width="14" height="80"  fill="#16864C" opacity="0.12" rx="2"/>
                <rect x="180" y="270" width="14" height="130" fill="#16864C" opacity="0.1"  rx="2"/>
                <rect x="270" y="215" width="14" height="185" fill="#16864C" opacity="0.09" rx="2"/>
                <rect x="360" y="165" width="14" height="235" fill="#16864C" opacity="0.08" rx="2"/>
                <rect x="450" y="110" width="14" height="290" fill="#16864C" opacity="0.07" rx="2"/>
                <rect x="540" y="70"  width="14" height="330" fill="#16864C" opacity="0.06" rx="2"/>
                <circle cx="200" cy="380" r="2" fill="rgba(196,154,44,0.3)"/>
                <circle cx="350" cy="350" r="2" fill="rgba(196,154,44,0.3)"/>
                <circle cx="500" cy="360" r="2" fill="rgba(196,154,44,0.2)"/>
                <circle cx="620" cy="340" r="2" fill="rgba(196,154,44,0.2)"/>
            </svg>
        </div>

        <div class="container">
            <div class="hero-inner">
                <!-- Left: Text content -->
                <div class="hero-left">
                    <div class="hero-badge-pill">DATA &nbsp;|&nbsp; RESEARCH &nbsp;|&nbsp; IMPACT</div>
                    <h1 class="hero-headline">
                        Hi, I'm<br>
                        <span class="hero-name">Daramola Joseph<br>Omoyele</span><span class="hero-dot">.</span>
                    </h1>
                    <p class="hero-tagline">Data Analyst. Research Analyst. Digital Product Builder.</p>
                    <p class="hero-description">
                        I build data-driven solutions, produce research outputs, create insightful dashboards, and design digital products that support smarter decisions and measurable impact across people, organisations and communities.
                    </p>
                    <div class="hero-cta">
                        <a href="#projects" class="btn btn-hero-primary">
                            View Projects
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                        <a href="#contact" class="btn btn-hero-outline">
                            Download CV
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </div>
                </div>

                <!-- Right: Photo -->
                <div class="hero-right">
                    <div class="hero-photo-frame">
                        <div class="hero-photo-ring" id="heroPhotoRing">
                            <img src="/images/profile-photo.jpg"
                                 alt="Daramola Joseph Omoyele"
                                 class="hero-photo"
                                 loading="eager"
                                 onerror="document.getElementById('heroPhotoRing').classList.add('no-photo')">
                            <div class="hero-photo-fallback">DJO</div>
                        </div>
                        <div class="photo-deco-dot photo-deco-1"></div>
                        <div class="photo-deco-dot photo-deco-2"></div>
                        <div class="photo-deco-dot photo-deco-3"></div>
                        <div class="photo-pulse-ring"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== ICON NAVIGATION ===================== -->
    <nav class="icon-nav-section" aria-label="Section quick links">
        <div class="container">
            <div class="icon-nav-grid">
                <a href="#featured-policy" class="icon-nav-tile active-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l2.9 6.5 7.1.6-5.4 4.7 1.7 6.9-6.3-3.8-6.3 3.8 1.7-6.9L2 9.1l7.1-.6z"/></svg>
                    <span class="icon-nav-label">Featured Policy</span>
                </a>
                <a href="#projects" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 4v-1M16 4v-1"/></svg>
                    <span class="icon-nav-label">Projects</span>
                </a>
                <a href="#experience" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/></svg>
                    <span class="icon-nav-label">Experience</span>
                </a>
                <a href="#research" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3L2 8l10 5 8-4.2V17"/><path d="M6 10.5V16c0 1.7 2.7 3 6 3s6-1.3 6-3v-5.5"/></svg>
                    <span class="icon-nav-label">Research</span>
                </a>
                <a href="#awards" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="5"/><path d="M8.5 12.5L7 21l5-2.5 5 2.5-1.5-8.5"/></svg>
                    <span class="icon-nav-label">Awards</span>
                </a>
                <a href="#skills" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="1"/></svg>
                    <span class="icon-nav-label">Expertise</span>
                </a>
                <a href="#publications" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 4.5h6a3 3 0 0 1 3 3V20a2.5 2.5 0 0 0-2.5-2.5H2zM22 4.5h-6a3 3 0 0 0-3 3V20a2.5 2.5 0 0 1 2.5-2.5H22z"/></svg>
                    <span class="icon-nav-label">Publications</span>
                </a>
                <a href="#books" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 3h11a2 2 0 0 1 2 2v16H7a2 2 0 0 1-2-2z"/><path d="M5 3a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2"/></svg>
                    <span class="icon-nav-label">Books</span>
                </a>
                <a href="#public-engagement" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 11v2a2 2 0 0 0 2 2h1l4 4v-6M10 9h8a3 3 0 0 0 0-6h-8z"/><path d="M3 11h4V9H5a2 2 0 0 0-2 2z"/></svg>
                    <span class="icon-nav-label">Media</span>
                </a>
                <a href="#policy" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3v18M5 7l-3 6a3.2 3.2 0 0 0 6 0zM19 7l-3 6a3.2 3.2 0 0 0 6 0zM5 7h14M3 21h18"/></svg>
                    <span class="icon-nav-label">Policy Work</span>
                </a>
                <a href="#impact" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 20V10M11 20V4M18 20v-7"/><path d="M3 20h18"/></svg>
                    <span class="icon-nav-label">Impact</span>
                </a>
                <a href="#education" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3L2 8l10 5 10-5z"/><path d="M6 10.5V16c0 1.7 2.7 3 6 3s6-1.3 6-3v-5.5"/></svg>
                    <span class="icon-nav-label">Education</span>
                </a>
                <a href="#contact" class="icon-nav-tile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <span class="icon-nav-label">Contact</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- ============ FEATURED POLICY CONTRIBUTION (homepage preview) ============ -->
    <section id="featured-policy" class="section fpc-preview-section">
        <div class="container">
            <a class="fpc-preview" href="/policy-contributions/">
                <div class="fpc-preview-body">
                    <span class="fpc-preview-tag">Featured Policy Contribution</span>
                    <h2 class="fpc-preview-title">Digital Identity Harmonisation in Nigeria</h2>
                    <p class="fpc-preview-text">Research, public commentary and a peer-reviewed publication examining Nigeria's digital identity infrastructure and the harmonisation of identification systems around the National Identification Number (NIN).</p>
                    <span class="fpc-preview-cta">Read More <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                </div>
                <div class="fpc-preview-aside" aria-hidden="true">
                    <span class="fpc-preview-pill">Peer-reviewed article · IJDES 2026</span>
                    <span class="fpc-preview-pill">National &amp; international media</span>
                    <span class="fpc-preview-pill">Policy relevance · NIMC Act 2026</span>
                </div>
            </a>
        </div>
    </section>

    <!-- ===================== FEATURED PROJECTS ===================== -->
    <section id="projects" class="section projects-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Portfolio</span>
                <h2 class="section-title">Featured Projects</h2>
            </div>
            <p class="section-preview-intro">A selection of digital products, dashboards and research tools spanning healthcare communication, tax compliance, governance and tourism.</p>
            <div class="project-grid">
                {% for project in collections.projects | reverse %}
                {% if loop.index <= 4 %}
                <div class="project-card reveal" data-category="{{ project.data.badge | lower | replace(' ', '-') }}">
                    <div class="project-card-top">
                        <div class="project-card-meta">
                            <span class="project-badge">{{ project.data.badge }}</span>
                            <span class="project-client-tag">{{ project.data.client }}</span>
                        </div>
                        <h3 class="project-title">{{ project.data.title }}</h3>
                        <p class="project-desc">{{ project.data.description }}</p>
                    </div>
                    <div class="project-card-mid">
                        <div class="project-highlights">
                            {% for highlight in project.data.highlights %}
                            {% if loop.index <= 2 %}
                            <div class="highlight-item"><span class="highlight-dot">▸</span><span>{{ highlight.text }}</span></div>
                            {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="project-card-foot">
                        {% if project.data.link and project.data.link != '#' %}
                        <a href="{{ project.data.link }}" target="_blank" rel="noopener" class="btn btn-primary btn-sm">
                            View Live Demo <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4.5 10H15.5M15.5 10L10.5 5M15.5 10L10.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                        {% else %}
                        <span class="btn btn-disabled btn-sm">Coming Soon</span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <a href="/projects/" class="btn btn-primary view-more-btn">View All Projects →</a>
        </div>
    </section>

    <!-- ===================== PROFESSIONAL EXPERIENCE (PREVIEW) ===================== -->
    <section id="experience" class="section experience-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Career Journey</span>
                <h2 class="section-title">Professional Experience</h2>
            </div>
            <p class="section-preview-intro">15+ years across public-sector data analysis, economic modelling, and academic administration.</p>
            <div class="exp-preview-grid">
                <div class="exp-preview-card reveal">
                    <div class="exp-preview-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/></svg>
                    </div>
                    <h3>Data &amp; Finance Analyst</h3>
                    <p class="exp-preview-company">Univelcity Computing</p>
                    <p class="exp-preview-date">July 2023 – Present</p>
                    <p class="role-focus">Data analysis, economic modelling, financial analysis, business intelligence and compliance assurance.</p>
                </div>
                <div class="exp-preview-card reveal">
                    <div class="exp-preview-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/></svg>
                    </div>
                    <h3>Data Analyst</h3>
                    <p class="exp-preview-company">Nigerian Postal Service</p>
                    <p class="exp-preview-date">January 2014 – October 2022</p>
                    <p class="role-focus">Public sector data analysis, operational insight, performance monitoring and forecasting.</p>
                </div>
                <div class="exp-preview-card reveal">
                    <div class="exp-preview-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/></svg>
                    </div>
                    <h3>Lecturer / Education Data Support</h3>
                    <p class="exp-preview-company">City College of Education</p>
                    <p class="exp-preview-date">April 2008 – March 2013</p>
                    <p class="role-focus">Student attendance, assessment outcomes and academic progress data for departmental reporting.</p>
                </div>
            </div>
            <a href="/experience/" class="btn btn-primary view-more-btn">View Full Experience →</a>
        </div>
    </section>

    <!-- ===================== ACADEMIC RESEARCH (PREVIEW) ===================== -->
    <section id="research" class="section research-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Academic Work</span>
                <h2 class="section-title">Academic Research</h2>
            </div>
            <p class="section-preview-intro">Major research initiatives spanning econometric modelling, institutional economics, and applied policy analysis.</p>
            <div class="research-grid">
                {% for item in collections.research | reverse %}
                <div class="research-card reveal">
                    <div class="research-badge">{{ item.data.badge }}</div>
                    <h3>{{ item.data.title }}</h3>
                    <p class="research-institution">{{ item.data.institution }}</p>
                    <div class="research-details">
                        <h4>Methodology / Focus areas:</h4>
                        <ul>{% for pt in item.data.items %}{% if loop.index <= 3 %}<li>{{ pt.text }}</li>{% endif %}{% endfor %}</ul>
                    </div>
                </div>
                {% endfor %}
            </div>
            <a href="/academic-work/" class="btn btn-primary view-more-btn">View All Research →</a>
        </div>
    </section>

    <!-- ===================== AWARDS & HONOURS (PREVIEW) ===================== -->
    <section id="awards" class="section awards-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Recognition</span>
                <h2 class="section-title">Awards &amp; Honours</h2>
            </div>
            <p class="section-preview-intro">Recognition for contributions to data analysis, research, and public-sector service.</p>
            <div class="awards-grid">
                {% for award in collections.awards | reverse %}
                <div class="award-card reveal">
                    {% if award.data.image %}
                    <div class="award-image-container">
                        <img src="{{ award.data.image }}" alt="{{ award.data.title }}" class="award-image" loading="lazy">
                    </div>
                    {% endif %}
                    <div class="award-content">
                        {% if award.data.badge %}<span class="award-badge">{{ award.data.badge }}</span>{% endif %}
                        <h3>{{ award.data.title }}</h3>
                        <p class="award-issuer">{{ award.data.issuer }}</p>
                        <div class="award-date"><span>📅 {{ award.data.date_issued }}</span></div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <a href="/awards/" class="btn btn-primary view-more-btn">View All Awards →</a>
        </div>
    </section>

    <!-- ===================== CORE EXPERTISE ===================== -->
    <section id="skills" class="section skills-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Technical Expertise</span>
                <h2 class="section-title">Core Expertise</h2>
            </div>
            <p class="section-preview-intro">A cross-disciplinary toolkit spanning economic analysis, econometrics, analytics engineering and regulatory compliance.</p>
            <div class="expertise-card reveal">
                <div class="expertise-tags">
                    <span class="expertise-tag">Data Analysis</span>
                    <span class="expertise-tag">Econometrics</span>
                    <span class="expertise-tag">Policy Analysis</span>
                    <span class="expertise-tag">R</span>
                    <span class="expertise-tag">Python</span>
                    <span class="expertise-tag">SQL</span>
                    <span class="expertise-tag">Power BI</span>
                    <span class="expertise-tag">Tableau</span>
                    <span class="expertise-tag">Machine Learning</span>
                    <span class="expertise-tag">Research Methods</span>
                    <span class="expertise-tag">RegTech</span>
                    <span class="expertise-tag">Digital Governance</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== PUBLICATIONS (PREVIEW) ===================== -->
    <section id="publications" class="section publications-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Thought Leadership</span>
                <h2 class="section-title">Latest Publications</h2>
            </div>
            <p class="section-preview-intro">Peer-reviewed journal articles across development economics, tax policy, and institutional analysis.</p>
            <div class="publications-grid">
                {% for article in collections.journal_articles | reverse %}
                {% if loop.index <= 3 %}
                <div class="publication-card journal-card reveal">
                    <div class="pub-icon">📄</div>
                    <h3>{{ article.data.title }}</h3>
                    <p class="pub-meta">{{ article.data.journal }}{% if article.data.year %} ({{ article.data.year }}){% endif %}</p>
                    {% if article.data.doi %}<p class="pub-doi"><a href="{{ article.data.doi }}" target="_blank" rel="noopener">DOI Link</a></p>{% endif %}
                    <p class="pub-summary">{{ article.templateContent | excerpt(2) }}</p>
                    <div class="pub-full-details collapsed">{{ article.templateContent | safe }}</div>
                    <button class="read-more-btn" aria-expanded="false">Read more ▾</button>
                    <a href="{{ article.data.url or article.data.doi }}" target="_blank" rel="noopener" class="pub-link">View Journal Article →</a>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <a href="/publications/" class="btn btn-primary view-more-btn">View All Publications →</a>
        </div>
    </section>

    <!-- ===================== BOOKS (PREVIEW) ===================== -->
    <section id="books" class="section publications-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Thought Leadership</span>
                <h2 class="section-title">Books &amp; Handbooks</h2>
            </div>
            <p class="section-preview-intro">Independently published books and handbooks distilling applied economics and data analysis for practitioners.</p>
            <div class="publications-grid">
                {% for book in collections.books | reverse %}
                {% if loop.index <= 3 %}
                <div class="publication-card book-card flip-card reveal">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <img src="{{ book.data.image }}" alt="{{ book.data.title }} Cover" class="book-cover-img" loading="lazy"/>
                            <div class="flip-hint">Hover to read more</div>
                        </div>
                        <div class="flip-card-back">
                            <h3>{{ book.data.title }}</h3>
                            <p class="pub-meta">Independently published ({{ book.data.year }})</p>
                            <div class="pub-description">{{ book.templateContent | safe }}</div>
                            <a href="{{ book.data.link }}" target="_blank" rel="noopener" class="pub-link">View on Amazon →</a>
                        </div>
                    </div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <a href="/books/" class="btn btn-primary view-more-btn">View All Books →</a>
        </div>
    </section>

    <!-- ============ PUBLIC ENGAGEMENT + POLICY CONTRIBUTIONS (paired) ============ -->
    <section class="section section-pair-wrap">
        <div class="container section-pair">
            <div id="public-engagement" class="section-pair-col">
                <div class="section-header section-header-left">
                    <span class="section-tag">Thought Leadership</span>
                    <h2 class="section-title">Public Engagement</h2>
                </div>
                <p class="section-preview-intro section-preview-intro-left">Translating economic evidence into public policy debate across major Nigerian media outlets.</p>
                <div class="publications-grid">
                    <div class="publication-card media-card reveal">
                        <div class="pub-icon">📰</div>
                        <div class="media-list">
                            {% for item in collections.media | reverse %}
                            {% if loop.index <= 3 %}
                            <div class="media-item">
                                <h4>{{ item.data.title }}</h4>
                                <p class="media-description">{{ item.data.description }} <span class="media-date">({{ item.data.date_issued }})</span></p>
                            </div>
                            {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
                <a href="/public-engagement/" class="btn btn-primary view-more-btn">View All Media →</a>
            </div>
            <div id="policy" class="section-pair-col">
                <div class="section-header section-header-left">
                    <span class="section-tag">Policy Engagement</span>
                    <h2 class="section-title">Policy Contributions</h2>
                </div>
                <p class="section-preview-intro section-preview-intro-left">Independent consultation responses across UK tax administration, data governance and public-sector digital reform.</p>
                <div class="policy-grid">
                    {% for item in collections.policy_contributions %}
                    {% if loop.index <= 3 %}
                    <div class="policy-card reveal">
                        <span class="policy-area">{{ item.data.area }}</span>
                        <h3>{{ item.data.title }}</h3>
                        <p class="policy-desc">{{ item.data.description }}</p>
                        {% if item.data.pdf %}
                        <a href="{{ item.data.pdf }}" target="_blank" rel="noopener" class="btn btn-soft btn-sm policy-btn">{{ item.data.pdf_label or "Read Submission" }}</a>
                        {% endif %}
                    </div>
                    {% endif %}
                    {% endfor %}
                </div>
