                        <div class="timeline-body">
                            <p class="role-focus"><strong>Role focus:</strong> Analysed student attendance, assessment outcomes, and academic progress data to support departmental reporting, quality assurance, curriculum planning, and evidence-based learner support.</p>
                            <h4>Key Responsibilities:</h4>
                            <ul>
                                <li>Supported teaching delivery, academic administration, student performance monitoring, and departmental reporting.</li>
                                <li>Monitored student attendance, assessment outcomes, engagement, and academic progress to support evidence-based academic decision-making.</li>
                                <li>Maintained assessment records and academic reporting systems, strengthening quality assurance and institutional documentation standards.</li>
                                <li>Compiled departmental reports and learning performance data to support curriculum planning, learner support, and academic improvement.</li>
                                <li>Liaised with academic staff and management to improve reporting standards, student progress documentation, and learning outcome monitoring.</li>
                                <li>Contributed to evidence-informed improvements in academic delivery, reporting processes, and student support practices.</li>
                            </ul>
                            <div class="impact-badge"><strong>Impact:</strong> Strengthened academic reporting, supported student progress tracking, and improved education administration.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== RESEARCH ===================== -->
    <section id="research" class="section research-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Academic Work</span>
                <h2 class="section-title">Research &amp; Major Projects</h2>
            </div>
            <div class="research-grid">
                {% for item in collections.research | reverse %}
                <div class="research-card {% if loop.first %}featured{% else %}reveal{% endif %}">
                    <div class="research-badge">{{ item.data.badge }}</div>
                    <h3>{{ item.data.title }}</h3>
                    <p class="research-institution">{{ item.data.institution }}</p>
                    <div class="research-details">
                        <h4>Methodology / Focus areas:</h4>
                        <ul>{% for pt in item.data.items %}<li>{{ pt.text }}</li>{% endfor %}</ul>
                        {% if item.data.outcome %}
                        <div class="research-outcome"><strong>Outcome:</strong> {{ item.data.outcome }}</div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- ===================== PROJECTS ===================== -->
    <section id="projects" class="section projects-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Portfolio</span>
                <h2 class="section-title">All Projects</h2>
            </div>
            <div class="project-filters">
                <button class="filter-btn active" data-filter="all">All Projects</button>
                <button class="filter-btn" data-filter="digital-product">Digital Products</button>
                <button class="filter-btn" data-filter="data-dashboard">Dashboards</button>
                <button class="filter-btn" data-filter="research-tool">Research Tools</button>
                <button class="filter-btn" data-filter="portfolio">Portfolio</button>
            </div>
            <div class="project-grid">
                {% for project in collections.projects | reverse %}
                <div class="project-card reveal" data-category="{{ project.data.badge | lower | replace(' ', '-') }}">
                    <div class="project-card-top">
                        <div class="project-card-meta">
                            <span class="project-badge">{{ project.data.badge }}</span>
                            <span class="project-client-tag">{{ project.data.client }}</span>
                        </div>
                        <h3 class="project-title">{{ project.data.title }}</h3>
                        <p class="project-desc">{{ project.data.description }}</p>
                    </div>
                    <div class="project-card-mid">
                        <div class="project-highlights">
                            {% for highlight in project.data.highlights %}
                            <div class="highlight-item"><span class="highlight-dot">▸</span><span>{{ highlight.text }}</span></div>
                            {% endfor %}
                        </div>
                        {% if project.data.tech %}
                        <div class="tech-tags">
                            {% for tag in project.data.tech %}<span class="tech-tag">{{ tag.tag }}</span>{% endfor %}
                        </div>
                        {% endif %}
                    </div>
                    <div class="project-card-foot">
                        {% if project.data.link and project.data.link != '#' %}
                        <a href="{{ project.data.link }}" target="_blank" rel="noopener" class="btn btn-primary btn-sm">
                            View Live Demo <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4.5 10H15.5M15.5 10L10.5 5M15.5 10L10.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                        {% else %}
                        <span class="btn btn-disabled btn-sm">Coming Soon</span>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- ===================== AWARDS ===================== -->
    <section id="awards" class="section awards-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Recognition</span>
                <h2 class="section-title">Awards &amp; Honours</h2>
            </div>
            <div class="awards-grid">
                {% for award in collections.awards | reverse %}
                <div class="award-card reveal">
                    {% if award.data.image %}
                    <div class="award-image-container">
                        <img src="{{ award.data.image }}" alt="{{ award.data.title }}" class="award-image" loading="lazy">
                    </div>
                    {% endif %}
                    <div class="award-content">
                        {% if award.data.badge %}<span class="award-badge">{{ award.data.badge }}</span>{% endif %}
                        <h3>{{ award.data.title }}</h3>
                        <p class="award-issuer">{{ award.data.issuer }}</p>
                        <div class="award-description">{{ award.templateContent | safe }}</div>
                        {% if award.data.coverage %}
                        <div class="coverage-details">
                            <span class="coverage-label">Media Coverage:</span>
                            <div class="coverage-links">
                                {% for item in award.data.coverage %}
                                <a href="{{ item.url }}" target="_blank" rel="noopener" class="news-pill">Source {{ loop.index }}</a>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                        <div class="award-date"><span>📅 {{ award.data.date_issued }}</span></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

