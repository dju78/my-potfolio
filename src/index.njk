<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daramola Joseph Omoyele | Economist & Senior Data Analyst</title>
    <meta name="description"
        content="Economist, Senior Data Analyst, and Regulatory & Policy Analytics Specialist with 15+ years of experience delivering data-driven economic insights for regulation, public finance, and policy design.">
    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap"
        rel="stylesheet">
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <span class="brand-initial">DJO</span>
                <span class="brand-name">Daramola Joseph Omoyele</span>
            </div>
            <ul class="nav-menu" id="navMenu">
                <li><a href="#home" class="nav-link active">Home</a></li>
                <li><a href="#about" class="nav-link">About</a></li>
                <li><a href="#experience" class="nav-link">Experience</a></li>
                <li><a href="#research" class="nav-link">Research</a></li>
                <li><a href="#projects" class="nav-link">Projects</a></li>
                <li><a href="#awards" class="nav-link">Awards</a></li>
                <li><a href="#skills" class="nav-link">Skills</a></li>
                <li><a href="#publications" class="nav-link">Publications</a></li>
                <li><a href="#contact" class="nav-link">Contact</a></li>
            </ul>
            <button class="nav-toggle" id="navToggle">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-background">
            <div class="gradient-orb orb-1"></div>
            <div class="gradient-orb orb-2"></div>
            <div class="gradient-orb orb-3"></div>
        </div>
        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Let's Connect
            </div>
            <h1 class="hero-title">
                <span class="title-line">Daramola Joseph</span>
                <span class="title-line gradient-text">Omoyele</span>
            </h1>
            <p class="hero-subtitle">Economist | Senior Data Analyst | Regulatory & Policy Analytics Specialist</p>
            <p class="hero-description">
                Delivering data-driven economic insights for regulation, public finance, and policy design with 15+
                years of experience
            </p>
            <div class="hero-cta">
                <a href="#contact" class="btn btn-primary">Get in Touch</a>
                <a href="#experience" class="btn btn-secondary">View Experience</a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <div class="stat-number">15+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">39</div>
                    <div class="stat-label">Countries Analyzed</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Data-Driven</div>
                </div>
            </div>
        </div>
        <div class="scroll-indicator">
            <span>Scroll to explore</span>
            <div class="scroll-arrow"></div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="section about-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Who I Am</span>
                <h2 class="section-title">Executive Value Proposition</h2>
            </div>
            <div class="about-grid">
                <div class="about-card reveal">
                    <div class="card-icon">📊</div>
                    <h3>Data-Driven Insights</h3>
                    <p>I deliver data-driven economic insight for regulation, public finance, and policy design,
                        supporting evidence-based decision-making under scrutiny.</p>
                </div>
                <div class="about-card reveal">
                    <div class="card-icon">🎯</div>
                    <h3>Advanced Expertise</h3>
                    <p>15+ years of public-sector and consulting experience combined with advanced applied econometrics
                        and regulatory compliance analytics.</p>
                </div>
                <div class="about-card reveal">
                    <div class="card-icon">💡</div>
                    <h3>Clear Communication</h3>
                    <p>Strong ability to communicate complex economic concepts to policymakers and non-technical
                        audiences, ensuring actionable insights.</p>
                </div>
            </div>
            <div class="value-proposition">
                <div class="vp-content">
                    <h3 class="vp-title">Strategic Positioning</h3>
                    <blockquote class="vp-quote">
                        "If regulators must justify decisions under scrutiny, who better than an economist who builds
                        auditable, data-driven systems?"
                    </blockquote>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="section experience-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Career Journey</span>
                <h2 class="section-title">Professional Experience</h2>
            </div>
            <div class="timeline">
                <div class="timeline-item reveal">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>Finance & Economic Analyst</h3>
                                <p class="company">Univelcity Consulting | UK</p>
                            </div>
                            <span class="timeline-date">July 2023 – Present</span>
                        </div>
                        <div class="timeline-body">
                            <h4>Key Responsibilities:</h4>
                            <ul>
                                <li>Deliver economic analysis for donor-funded development programmes</li>
                                <li>Apply econometric modelling across GBP, USD, EUR, and NGN environments</li>
                                <li>Build automated dashboards reducing reporting time by 30%</li>
                                <li>Conduct cost-benefit analysis, forecasting, and risk assessment</li>
                                <li>Lead data governance aligned with GDPR and international standards</li>
                                <li>Train analysts on compliance, analytics, and quality assurance</li>
                            </ul>
                            <div class="impact-badge">
                                <strong>Impact:</strong> Faster decisions • Higher analytical confidence • Stronger
                                regulatory compliance
                            </div>
                        </div>
                    </div>
                </div>

                <div class="timeline-item reveal">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>Financial & Economic Data Analyst</h3>
                                <p class="company">Office of the Accountant General | Nigeria</p>
                            </div>
                            <span class="timeline-date">January 2014 – September 2022</span>
                        </div>
                        <div class="timeline-body">
                            <h4>Key Responsibilities:</h4>
                            <ul>
                                <li>Evaluated fiscal policy and public expenditure performance</li>
                                <li>Delivered impact assessments and ex-post evaluations</li>
                                <li>Reduced reporting cycles by 35%</li>
                                <li>Built econometric models linking spending to outcomes</li>
                                <li>Produced senior-level policy briefings</li>
                            </ul>
                            <div class="impact-badge">
                                <strong>Impact:</strong> Improved budget accountability • Stronger evidence for policy
                                design
                            </div>
                        </div>
                    </div>
                </div>

                <div class="timeline-item reveal">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <div>
                                <h3>Data Analyst</h3>
                                <p class="company">Nigerian Postal Service | Nigeria</p>
                            </div>
                            <span class="timeline-date">January 2008 – November 2013</span>
                        </div>
                        <div class="timeline-body">
                            <h4>Key Responsibilities:</h4>
                            <ul>
                                <li>Analysed nationwide operational and socioeconomic datasets</li>
                                <li>Built forecasting and efficiency models</li>
                                <li>Delivered a 20% improvement in operational efficiency</li>
                                <li>Designed composite performance indices</li>
                                <li>Guided regional offices on survey and data standards</li>
                            </ul>
                            <div class="impact-badge">
                                <strong>Impact:</strong> Measurable service delivery gains • Data-driven operational
                                planning
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Research Section -->
    <section id="research" class="section research-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Academic Work</span>
                <h2 class="section-title">Research & Major Projects</h2>
            </div>
            <div class="research-grid">
                {% for item in collections.research | reverse %}
                <div class="research-card {% if loop.first %}featured{% else %}reveal{% endif %}">
                    <div class="research-badge">{{ item.data.badge }}</div>
                    <h3>{{ item.data.title }}</h3>
                    <p class="research-institution">{{ item.data.institution }}</p>
                    <div class="research-details">
                        <h4>Methodology/Focus areas:</h4>
                        <ul>
                            {% for pt in item.data.items %}
                            <li>{{ pt.text }}</li>
                            {% endfor %}
                        </ul>
                        {% if item.data.outcome %}
                        <div class="research-outcome">
                            <strong>Outcome:</strong> {{ item.data.outcome }}
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="section projects-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Portfolio</span>
                <h2 class="section-title">Featured Projects</h2>
            </div>
            <div class="project-showcase">
                {% for project in collections.projects | reverse %}
                <div class="project-card {% if loop.first %}featured-project{% endif %} reveal">
                    <div class="project-header">
                        <div class="project-badge">{{ project.data.badge }}</div>
                        <h3>{{ project.data.title }}</h3>
                        <p class="project-client">{{ project.data.client }}</p>
                    </div>
                    <div class="project-content">
                        <div class="project-description">
                            <h4>Project Overview</h4>
                            <p>{{ project.data.description }}</p>
                        </div>
                        <div class="project-features">
                            <h4>Key Features</h4>
                            <div class="features-grid">
                                {% for highlight in project.data.highlights %}
                                <div class="feature-item">
                                    <div class="feature-icon">⚡</div>
                                    <p>{{ highlight.text }}</p>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="project-tech">
                            <h4>Technical Implementation</h4>
                            <div class="tech-tags">
                                {% for tag in project.data.tags %}
                                <span class="tech-tag">{{ tag.tag }}</span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="project-actions">
                            <a href="{{ project.data.link }}" target="_blank" class="btn btn-primary">
                                <span>View Live Demo</span>
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path d="M4.5 10H15.5M15.5 10L10.5 5M15.5 10L10.5 15" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Awards Section -->
    <section id="awards" class="section awards-section reveal">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Recognition</span>
                <h2 class="section-title">Awards & Honours</h2>
            </div>
            <div class="awards-grid">
                {% for award in collections.awards | reverse %}
                <div class="award-card reveal">
                    {% if award.data.image %}
                    <div class="award-image-container">
                        <img src="{{ award.data.image }}" alt="{{ award.data.title }}" class="award-image">
                    </div>
                    {% endif %}
                    <div class="award-content">
                        {% if award.data.badge %}
                        <span class="award-badge">{{ award.data.badge }}</span>
                        {% endif %}
                        <h3>{{ award.data.title }}</h3>
                        <p class="award-issuer">{{ award.data.issuer }}</p>
                        <div class="award-description">
                            {{ award.templateContent | safe }}
                        </div>
                        {% if award.data.coverage %}
                        <div class="coverage-details" style="margin-top: 1rem; margin-bottom: 1rem;">
                            <span class="coverage-label" style="font-size: 0.8rem;">Media Coverage:</span>
                            <div class="coverage-links">
                                {% for item in award.data.coverage %}
                                <a href="{{ item.url }}" target="_blank" class="news-pill">Source {{ loop.index }}</a>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                        <div class="award-date">
                            <span>📅 {{ award.data.date_issued }}</span>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="section skills-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Technical Expertise</span>
                <h2 class="section-title">Core Capability Stack</h2>
            </div>
            <div class="skills-grid">
                <div class="skill-category reveal">
                    <div class="category-header">
                        <div class="category-icon">📈</div>
                        <h3>Economic & Policy Analysis</h3>
                    </div>
                    <ul class="skill-list">
                        <li>Regulatory economics and impact assessment</li>
                        <li>Cost-benefit analysis and options appraisal</li>
                        <li>Forecasting and policy evaluation</li>
                        <li>HMT Green Book & Magenta Book aligned analysis</li>
                    </ul>
                </div>

                <div class="skill-category reveal">
                    <div class="category-header">
                        <div class="category-icon">🔬</div>
                        <h3>Econometrics & Data Science</h3>
                    </div>
                    <ul class="skill-list">
                        <li>Panel ARDL, panel data, time series, regression</li>
                        <li>Composite index construction</li>
                        <li>Large-scale administrative data analysis</li>
                        <li>Survey design and validation</li>
                    </ul>
                </div>

                <div class="skill-category reveal">
                    <div class="category-header">
                        <div class="category-icon">💻</div>
                        <h3>Analytics & Visualisation</h3>
                    </div>
                    <ul class="skill-list">
                        <li>R (advanced), Python, SQL</li>
                        <li>Power BI, Tableau, Shiny, ggplot2</li>
                        <li>Automated dashboards and decision-support systems</li>
                    </ul>
                </div>

                <div class="skill-category reveal">
                    <div class="category-header">
                        <div class="category-icon">🛡️</div>
                        <h3>Governance & Compliance</h3>
                    </div>
                    <ul class="skill-list">
                        <li>RegTech and compliance analytics</li>
                        <li>GDPR and data governance frameworks</li>
                        <li>Data quality assurance and ETL pipelines</li>
                    </ul>
                </div>
            </div>

            <div class="certifications">
                <h3 class="cert-title">Certifications & Professional Development</h3>
                <div class="cert-grid">
                    <div class="cert-badge">Certified National Accountant (CNA)</div>
                    <div class="cert-badge">Google Data Analytics Professional Certificate</div>
                    <div class="cert-badge">Advanced SQL for Data Analysis</div>
                    <div class="cert-badge">Microsoft Power BI Advanced Reporting</div>
                    <div class="cert-badge">GDPR & Data Protection Training</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Publications Section -->
    <section id="publications" class="section publications-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Thought Leadership</span>
                <h2 class="section-title">Publications & Public Engagement</h2>
            </div>
            <div class="pub-section journal-articles">
                <h3 class="pub-category-title"><span>Published</span> Journal Articles</h3>
                <div class="publications-grid">
                    {% for article in collections.journal_articles | reverse %}
                    <div class="publication-card journal-card reveal">
                        <div class="pub-icon">📄</div>
                        <h3>{{ article.data.title }}</h3>
                        <p class="pub-meta">{{ article.data.journal }} ({{ article.data.year }})</p>
                        {% if article.data.doi %}
                        <p class="pub-doi"><a href="{{ article.data.doi }}" target="_blank">DOI Link</a></p>
                        {% endif %}
                        <div class="pub-description">
                            {{ article.templateContent | safe }}
                        </div>
                        {% if article.data.contributors %}
                        <div class="pub-contributors" style="font-size: 0.85rem; color: var(--text-light); margin-top: 0.5rem;">
                            <strong>Contributors:</strong> {{ article.data.contributors }}
                        </div>
                        {% endif %}
                        <a href="{{ article.data.doi }}" target="_blank" class="pub-link" style="margin-top: 1rem;">View Journal Article</a>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section preprints">
                <h3 class="pub-category-title"><span>Working</span> Papers & Preprints</h3>
                <div class="publications-grid">
                    {% for paper in collections.working_papers | reverse %}
                    <div class="publication-card journal-card reveal">
                        <div class="pub-icon">📄</div>
                        <h3>{{ paper.data.title }}</h3>
                        <p class="pub-meta">{{ paper.data.journal }} ({{ paper.data.year }})</p>
                        {% if paper.data.doi %}
                        <p class="pub-doi"><a href="{{ paper.data.doi }}" target="_blank">DOI Link</a></p>
                        {% endif %}
                        <div class="pub-description">
                            {{ paper.templateContent | safe }}
                        </div>
                        {% if paper.data.contributors %}
                        <div class="pub-contributors" style="font-size: 0.85rem; color: var(--text-light); margin-top: 0.5rem;">
                            <strong>Contributors:</strong> {{ paper.data.contributors }}
                        </div>
                        {% endif %}
                        <a href="{{ paper.data.doi }}" target="_blank" class="pub-link" style="margin-top: 1rem;">View Preprint Article</a>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section books">
                <h3 class="pub-category-title"><span>Books</span> & Handbooks</h3>
                <div class="publications-grid">
                    {% for book in collections.books | reverse %}
                    <div class="publication-card book-card flip-card reveal">
                        <div class="flip-card-inner">
                            <div class="flip-card-front">
                                <img src="{{ book.data.image }}" alt="{{ book.data.title }} Cover" class="book-cover-img" />
                            </div>
                            <div class="flip-card-back">
                                <h3>{{ book.data.title }}</h3>
                                {% if book.data.subtitle %}
                                <p class="pub-subtitle"><strong>Subtitle:</strong> {{ book.data.subtitle }}</p>
                                {% endif %}
                                <p class="pub-meta">Independently published ({{ book.data.year }})</p>
                                {% if book.data.isbn %}
                                <p class="pub-isbn">ISBN: {{ book.data.isbn }}</p>
                                {% endif %}
                                {% if book.data.asin %}
                                <p class="pub-isbn">ASIN: {{ book.data.asin }}</p>
                                {% endif %}
                                <div class="pub-description">
                                    {{ book.templateContent | safe }}
                                </div>
                                <a href="{{ book.data.link }}" target="_blank" class="pub-link">View on Amazon</a>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="pub-section policy-media">
                <h3 class="pub-category-title"><span>Public</span> Engagement & Policy Commentary</h3>
                <div class="publications-grid">
                    <div class="publication-card media-card reveal">
                        <div class="pub-icon">📰</div>
                        <h3>Media & Policy Commentary</h3>
                        <div class="media-list">
                            {% for item in collections.media | reverse %}
                            <div class="media-item">
                                <h4>{{ item.data.title }}</h4>
                                <p class="media-description">{{ item.data.description }} ({{ item.data.date_issued }})</p>
                                <div class="coverage-details">
                                    <span class="coverage-label">Published in:</span>
                                    <div class="coverage-links">
                                        {% for source in item.data.coverage %}
                                        <a href="{{ source.url }}" target="_blank" class="news-pill">{{ source.source }}</a>
                                        {% endfor %}
                                    </div>
                                    {% if item.data.other_platforms %}
                                    <p class="other-coverage">{{ item.data.other_platforms }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        <p class="pub-description">
                            Consistently translating economic evidence into public policy debate for wider audiences across major Nigerian media outlets.
                        </p>
                    </div>
                </div>
            </div>

            <div class="interests-section">
                <h3>Professional Interests</h3>
                <div class="interests-tags">
                    <span class="interest-tag">Economic regulation and innovation</span>
                    <span class="interest-tag">Data protection and privacy economics</span>
                    <span class="interest-tag">RegTech and compliance analytics</span>
                    <span class="interest-tag">Digital identity and governance</span>
                    <span class="interest-tag">Housing affordability and public finance</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section contact-section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Let's Connect</span>
                <h2 class="section-title">Get in Touch</h2>
            </div>
            <div class="contact-content">
                <div class="contact-info">
                    <div class="contact-card reveal">
                        <div class="contact-icon">📧</div>
                        <h3>Email</h3>
                        <p><a href="mailto:dju78@yahoo.com">dju78@yahoo.com</a></p>
                        <p><a href="mailto:1978dju@gmail.com">1978dju@gmail.com</a></p>
                    </div>
                    <div class="contact-card reveal">
                        <div class="contact-icon">📍</div>
                        <h3>Location</h3>
                        <p>Colchester, Essex</p>
                        <p>United Kingdom</p>
                    </div>
                    <div class="contact-card reveal">
                        <div class="contact-icon">🔬</div>
                        <h3>ORCID iD</h3>
                        <p><a href="https://orcid.org/0009-0006-0347-0499" target="_blank">0009-0006-0347-0499</a></p>
                    </div>
                </div>
                <div class="availability-card">
                    <div class="availability-badge">
                        <span class="badge-dot pulse"></span>
                        Let's Connect
                    </div>
                    <h3>Availability</h3>
                    <p>Open to hybrid, full-time, or part-time roles and travel as required.</p>
                    <p class="availability-note">Ready to bring data-driven economic insights to your organization.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <h3>Daramola Joseph Omoyele</h3>
                    <p>Economist | Senior Data Analyst | Regulatory & Policy Analytics Specialist</p>
                </div>
                <div class="footer-links">
                    <a href="#home">Home</a>
                    <a href="#about">About</a>
                    <a href="#experience">Experience</a>
                    <a href="#research">Research</a>
                    <a href="#projects">Projects</a>
                    <a href="#awards">Awards</a>
                    <a href="#skills">Skills</a>
                    <a href="#publications">Publications</a>
                    <a href="#contact">Contact</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Daramola Joseph Omoyele. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>

</html>